### 2.2 Integration Tables

```sql
-- Links learning back to main CRM entities
CREATE TABLE customer_learned_preferences (
    customer_id UUID NOT NULL,
    preference_category VARCHAR(50) NOT NULL,  -- 'communication', 'product', 'timing', 'pricing'
    preferences JSONB NOT NULL,
    confidence DECIMAL(5,4),
    last_updated TIMESTAMP DEFAULT NOW(),
    
    PRIMARY KEY (customer_id, preference_category),
    FOREIGN KEY (customer_id) REFERENCES customers(id)
);


-- Tracks agent performance improvement
CREATE TABLE agent_performance_metrics (
    agent_id UUID NOT NULL,
    metric_date DATE NOT NULL,
    
    -- Conversation metrics
    conversations_started INTEGER DEFAULT 0,
    conversations_completed INTEGER DEFAULT 0,
    avg_conversation_length INTERVAL,
    
    -- Outcome metrics
    meetings_booked INTEGER DEFAULT 0,
    orders_placed INTEGER DEFAULT 0,
    questions_resolved INTEGER DEFAULT 0,
    total_conversion_value DECIMAL(12,2),
    
    -- Learning metrics
    patterns_discovered INTEGER DEFAULT 0,
    patterns_applied INTEGER DEFAULT 0,
    user_corrections INTEGER DEFAULT 0,
    
    -- Quality metrics
    avg_user_satisfaction DECIMAL(3,2),  -- 1.00 to 5.00
    error_rate DECIMAL(5,4),
    
    PRIMARY KEY (agent_id, metric_date),
    FOREIGN KEY (agent_id) REFERENCES agents(id)
);

CREATE INDEX idx_agent_metrics_date ON agent_performance_metrics(metric_date DESC);
```

