## 2. Database Schema

### 2.1 Core Tables

```sql
-- Interaction memory
CREATE TABLE agent_interactions (
    id UUID PRIMARY KEY,
    agent_id UUID NOT NULL,
    customer_id UUID NOT NULL,
    conversation_id UUID NOT NULL,  -- Thread related interactions
    channel VARCHAR(50) NOT NULL,  -- 'email', 'chat', 'call', 'sms'
    direction VARCHAR(10) NOT NULL,  -- 'inbound', 'outbound'
    
    -- Content
    full_context JSONB NOT NULL,  -- Complete interaction including agent reasoning
    summary TEXT,
    key_topics VARCHAR[] NOT NULL DEFAULT '{}',
    
    -- Outcomes
    outcome_type VARCHAR(50),  -- 'meeting_booked', 'order_placed', 'question_answered', etc.
    outcome_success BOOLEAN,
    conversion_value DECIMAL(10,2),
    
    -- Learning signals
    user_feedback JSONB,  -- Thumbs up/down, corrections, annotations
    implicit_signals JSONB,  -- Opens, response time, etc.
    
    -- Metadata
    occurred_at TIMESTAMP NOT NULL,
    created_at TIMESTAMP DEFAULT NOW(),
    
    FOREIGN KEY (agent_id) REFERENCES agents(id),
    FOREIGN KEY (customer_id) REFERENCES customers(id)
);

CREATE INDEX idx_interactions_customer ON agent_interactions(customer_id, occurred_at DESC);
CREATE INDEX idx_interactions_conversation ON agent_interactions(conversation_id);
CREATE INDEX idx_interactions_outcome ON agent_interactions(outcome_type, outcome_success);
CREATE INDEX idx_interactions_topics ON agent_interactions USING GIN(key_topics);


-- Learned patterns
CREATE TABLE learned_patterns (
    id UUID PRIMARY KEY,
    pattern_type VARCHAR(50) NOT NULL,  -- 'customer_segment', 'communication_style', 'timing', 'offer_type'
    
    -- Pattern definition
    conditions JSONB NOT NULL,  -- What triggers this pattern
    recommendation JSONB NOT NULL,  -- What to do when pattern matches
    
    -- Evidence
    supporting_interactions UUID[] NOT NULL DEFAULT '{}',  -- IDs of interactions that support this pattern
    sample_size INTEGER NOT NULL DEFAULT 0,
    success_rate DECIMAL(5,4),  -- 0.0000 to 1.0000
    confidence_score DECIMAL(5,4),
    
    -- Validation
    last_validated_at TIMESTAMP,
    validation_status VARCHAR(20) DEFAULT 'active',  -- 'active', 'testing', 'deprecated'
    
    -- Metadata
    discovered_at TIMESTAMP DEFAULT NOW(),
    created_by VARCHAR(50) DEFAULT 'system',  -- 'system' or 'user'
    
    UNIQUE(pattern_type, conditions)
);

CREATE INDEX idx_patterns_type ON learned_patterns(pattern_type, validation_status);
CREATE INDEX idx_patterns_confidence ON learned_patterns(confidence_score DESC);


-- Entity resolution learning
CREATE TABLE entity_resolution_rules (
    id UUID PRIMARY KEY,
    entity_type VARCHAR(50) NOT NULL,  -- 'brewery', 'pub', 'contact', 'product'
    
    -- Rule definition
    rule_type VARCHAR(50) NOT NULL,  -- 'merge_signal', 'split_signal', 'similarity_weight'
    rule_logic JSONB NOT NULL,
    
    -- Learned from
    source_type VARCHAR(20) NOT NULL,  -- 'user_correction', 'validation', 'automated'
    source_interactions UUID[] NOT NULL DEFAULT '{}',
    
    -- Performance
    true_positives INTEGER DEFAULT 0,
    false_positives INTEGER DEFAULT 0,
    precision DECIMAL(5,4),
    
    -- Metadata
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP DEFAULT NOW(),
    active BOOLEAN DEFAULT TRUE
);

CREATE INDEX idx_resolution_entity_type ON entity_resolution_rules(entity_type, active);


-- Knowledge graph
CREATE TABLE learned_facts (
    id UUID PRIMARY KEY,
    entity_id UUID NOT NULL,  -- Brewery, customer, product, etc.
    entity_type VARCHAR(50) NOT NULL,
    
    -- Fact
    fact_type VARCHAR(100) NOT NULL,  -- 'product_preference', 'ordering_pattern', 'communication_preference'
    fact_key VARCHAR(255) NOT NULL,
    fact_value JSONB NOT NULL,
    
    -- Confidence
    confidence_score DECIMAL(5,4) NOT NULL,
    supporting_evidence UUID[] NOT NULL DEFAULT '{}',  -- Interaction IDs
    
    -- Temporal
    valid_from TIMESTAMP NOT NULL,
    valid_to TIMESTAMP,  -- NULL if currently valid
    
    -- Metadata
    learned_at TIMESTAMP DEFAULT NOW(),
    last_confirmed_at TIMESTAMP,
    
    UNIQUE(entity_id, fact_type, fact_key, valid_from)
);

CREATE INDEX idx_facts_entity ON learned_facts(entity_id, entity_type);
CREATE INDEX idx_facts_type ON learned_facts(fact_type);
CREATE INDEX idx_facts_validity ON learned_facts(valid_to) WHERE valid_to IS NULL;


-- Strategy performance
CREATE TABLE agent_strategies (
    id UUID PRIMARY KEY,
    strategy_name VARCHAR(100) NOT NULL,
    strategy_description TEXT,
    
    -- Application context
    applies_to_segment VARCHAR(50),  -- Customer segment this works for
    applies_to_scenario VARCHAR(50),  -- Scenario type
    
    -- Strategy definition
    approach JSONB NOT NULL,  -- Tone, timing, content structure, etc.
    
    -- Performance tracking
    times_used INTEGER DEFAULT 0,
    success_count INTEGER DEFAULT 0,
    failure_count INTEGER DEFAULT 0,
    avg_conversion_value DECIMAL(10,2),
    
    -- A/B testing
    test_group VARCHAR(50),  -- If part of an experiment
    control_strategy_id UUID,  -- Reference to baseline
    
    -- Metadata
    created_at TIMESTAMP DEFAULT NOW(),
    active BOOLEAN DEFAULT TRUE,
    
    FOREIGN KEY (control_strategy_id) REFERENCES agent_strategies(id)
);

CREATE INDEX idx_strategies_segment ON agent_strategies(applies_to_segment, active);
```

